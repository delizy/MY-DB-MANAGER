# =============================================================================
# PROJECT_DB - Production Environment Template
# Generated: 2026-03-28
# =============================================================================
# HOW TO USE:
#   1. Copy this file:   cp env.production.template .env.production
#   2. Fill in every value marked  <REPLACE_THIS>
#   3. Load it before starting the server:
#        export $(grep -v '^#' .env.production | xargs)
#      OR use a process manager like PM2:
#        pm2 start ecosystem.config.js
# =============================================================================


# --- Node Environment ---------------------------------------------------------
NODE_ENV=production


# --- API Server ---------------------------------------------------------------
# Port the Express API server listens on.
PORT=8080

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info


# --- PostgreSQL Connection ----------------------------------------------------
# Full DSN used by Drizzle ORM (the application reads this variable).
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# On your VPS after restoring the dump, the database name will be: heliumdb
# (unless you rename it — in that case update the connection string accordingly)
DATABASE_URL=postgresql://postgres:<REPLACE_WITH_YOUR_POSTGRES_PASSWORD>@localhost:5432/heliumdb

# Individual parameters used by CLI tools (psql, pg_dump, drizzle-kit).
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=<REPLACE_WITH_YOUR_POSTGRES_PASSWORD>
PGDATABASE=heliumdb


# --- Session Secret -----------------------------------------------------------
# Must be a long random string. Generate one with:
#   openssl rand -hex 64
SESSION_SECRET=<REPLACE_WITH_OUTPUT_OF: openssl rand -hex 64>


# =============================================================================
# WHERE TO FIND YOUR CURRENT SECRET VALUES (while on Replit)
# =============================================================================
# Go to:  Replit workspace → Tools → Secrets (or .env panel)
# Copy the values for:
#   - PGPASSWORD       → paste into PGPASSWORD and DATABASE_URL above
#   - SESSION_SECRET   → paste into SESSION_SECRET above
# All other values (host, port, user, database name) are shown above exactly
# as they are on Replit, but you will change them to match your VPS PostgreSQL.
# =============================================================================


# =============================================================================
# VPS SETUP CHECKLIST (Ubuntu / Debian example)
# =============================================================================
#
# 1. INSTALL RUNTIME DEPENDENCIES
#    curl -fsSL https://deb.nodesource.com/setup_20.x | sudo bash -
#    sudo apt-get install -y nodejs postgresql
#    npm install -g pnpm
#
# 2. CREATE THE DATABASE
#    sudo -u postgres psql -c "CREATE DATABASE heliumdb;"
#    sudo -u postgres psql -c "ALTER USER postgres PASSWORD '<your-password>';"
#
# 3. RESTORE THE BACKUP
#    psql -U postgres heliumdb < database_backup.sql
#    (The dump includes all tables, indexes, and data rows.)
#
# 4. UPLOAD & INSTALL PROJECT
#    # Upload the project zip to your VPS, then:
#    unzip project.zip && cd <project-folder>
#    pnpm install --frozen-lockfile
#
# 5. BUILD FRONTEND
#    pnpm --filter @workspace/project-db run build
#    # Output will be in:  artifacts/project-db/dist/
#
# 6. START THE API SERVER
#    export $(grep -v '^#' .env.production | xargs)
#    cd artifacts/api-server
#    pnpm start
#    # Or with PM2 (recommended for production):
#    pm2 start "pnpm start" --name project-db-api --cwd artifacts/api-server
#
# 7. SERVE THE FRONTEND
#    Serve artifacts/project-db/dist/ as static files with nginx/caddy,
#    and reverse-proxy  /api/*  to  http://localhost:8080/api
#
#    Minimal nginx config example:
